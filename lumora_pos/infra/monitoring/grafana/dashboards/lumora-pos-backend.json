    {
      "title": "Request rate (req/s)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "sum(rate(http_server_requests_seconds_count{application=\"lumora-pos\"}[1m]))",
          "legendFormat": "all",
          "refId": "A"
        },
        {
          "expr": "sum by (status) (rate(http_server_requests_seconds_count{application=\"lumora-pos\"}[1m]))",
          "legendFormat": "{{status}}",
          "refId": "B"
        }
      ]
    },
    {
